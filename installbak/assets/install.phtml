<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script type="text/javascript">
function nextStep(step) {
    if (step > 1 && !validateCurrentStep(step - 1)) return;

    $('.step-content').hide();
    $('#step-' + step).fadeIn();
}

function prevStep(step) {
    $('.step-content').hide();
    $('#step-' + step).fadeIn();
}

function validateCurrentStep(step) {
    if (step === 1) {
        if (!$('#agree').is(':checked')) {
            alert('Please agree to the Terms of Service to continue.');
            return false;
        }
<?php if (empty($all_ok)) : ?>
        alert('Your system does not meet all requirements. Please resolve the issues marked in red.');
        return false;
<?php endif; ?>
    }

    if (step === 2) {
        if (!$('#db_host').val() || !$('#db_name').val() || !$('#db_user').val()) {
            alert('Please fill in all database connectivity details.');
            return false;
        }
        var ok = false;
        $.ajax({
            async: false,
            type: "POST",
            url: 'install.php?a=check-db',
            data: $('#installer').serialize(),
            success: function(msg) {
                if (msg == 'ok') ok = true;
                else alert(msg);
            }
        });
        return ok;
    }

    if (step === 3) {
        if (!$('#admin_name').val() || !$('#admin_email').val() || !$('#admin_pass').val()) {
            alert('Please provide administrator account details.');
            return false;
        }
    }
    return true;
}

function startInstallation() {
    $('#final-actions').hide();
    $('#install-progress').show();

    $.ajax({
        type: "POST",
        url: 'install.php?a=install',
        data: $('#installer').serialize(),
        success: function(msg) {
            $('#install-progress').hide();
            if (msg == 'ok') {
                $('#install-success').fadeIn();
            } else {
                alert("Installation Error: " + msg);
                $('#final-actions').show();
            }
        }
    });
}
</script>
